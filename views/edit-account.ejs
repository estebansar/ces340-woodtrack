<%- include("partials/header", { title: "Edit Account" }) %>

<section class="hero">
  <h1>Edit Account</h1>

  <p>Update your account information below.</p>

  <form action="/account/edit" method="post">
    <label for="name">Name</label>
    <input
      type="text"
      id="name"
      name="name"
      value="<%= account.name %>"
      required
    >

    <label for="email">Email</label>
    <input
      type="email"
      id="email"
      name="email"
      value="<%= account.email %>"
      required
    >

    <button type="submit">Save Changes</button>
  </form>
</section>

<%- include("partials/footer") %>