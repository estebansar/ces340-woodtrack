<%- include("partials/header", { title: "Dashboard" }) %>

<section class="hero">
  <h1>Dashboard</h1>

  <p>Welcome, <%= user.name %>.</p>
  <p>Your email: <%= user.email %></p>
  <p>Your role: <%= user.role %></p>

  <p>You are logged in with a session.</p>

<h2>Your Custom Build Requests</h2>

<% if (!requests || requests.length === 0) { %>
  <p>You have not submitted any requests yet.</p>
<% } else { %>
  <% requests.forEach(request => { %>
    <div class="request-card">
      <h3><%= request.request_title %></h3>
      <p><strong>Description:</strong> <%= request.request_description %></p>
      <p><strong>Status:</strong> <%= request.request_status %></p>
      <p><strong>Submitted:</strong> <%= request.created_at %></p>
    </div>
  <% }) %>
<% } %>

</section>

<%- include("partials/footer") %>
