<%- include("partials/header", { title: "Dashboard" }) %>

<section class="hero">
  <h1>Dashboard</h1>

  <div class="card">
    <h3>Account Info</h3>
    <p><strong>Name:</strong> <%= user.name %></p>
    <p><strong>Email:</strong> <%= user.email %></p>
    <p><strong>Role:</strong> <%= user.role %></p>
    <p>You are logged in with a session.</p>
    <p><a href="/account/edit">Edit My Account</a></p>
  </div>

  <h2 class="section-title">Your Custom Build Requests</h2>

  <% if (requests.length === 0) { %>
    <p>No requests submitted yet.</p>
  <% } %>

  <% requests.forEach(request => { %>
    <div class="card">
      <h3><%= request.request_title || request.title %></h3>

      <p><strong>Description:</strong>
        <%= request.request_description || request.description %>
      </p>

      <p>
        <strong>Status:</strong>
        <span class="status <%= request.status === "submitted" ? "status-submitted" : "" %><%= request.status === "in progress" ? " status-progress" : "" %><%= request.status === "completed" ? " status-completed" : "" %>">
          <%= request.status %>
        </span>
      </p>

      <p>
        <strong>Submitted:</strong>
        <%= new Date(request.created_at).toLocaleString() %>
      </p>
    </div>
  <% }) %>
</section>

<%- include("partials/footer") %>
