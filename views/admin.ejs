<%- include("partials/header", { title: "Admin Dashboard" }) %>

<section class="hero">
  <h1>Admin Dashboard</h1>

  <div class="card">
    <h3>Admin Info</h3>
    <p><strong>Name:</strong> <%= user.name %></p>
    <p><strong>Role:</strong> <%= user.role %></p>
    <p>This page is restricted to admin users only.</p>
  </div>

  <h2 class="section-title">All Submitted Requests</h2>

  <% if (requests.length === 0) { %>
    <p>No requests found.</p>
  <% } %>

  <% requests.forEach(request => { %>
    <div class="card">

      <h3><%= request.request_title %></h3>

      <p>
        <strong>Submitted by:</strong>
        <%= request.user_name %> (<%= request.user_email %>)
      </p>

      <p>
        <strong>Description:</strong>
        <%= request.request_description %>
      </p>

      <form action="/admin/requests/<%= request.request_id %>/status" method="post">
        <label for="status-<%= request.request_id %>">Status</label>
        <select id="status-<%= request.request_id %>" name="status">
          <option value="submitted" <%= request.request_status === "submitted" ? "selected" : "" %>>submitted</option>
          <option value="in progress" <%= request.request_status === "in progress" ? "selected" : "" %>>in progress</option>
          <option value="completed" <%= request.request_status === "completed" ? "selected" : "" %>>completed</option>
        </select>

        <button type="submit">Update Status</button>
      </form>

      <p>
        <strong>Submitted:</strong>
        <%= new Date(request.created_at).toLocaleString() %>
      </p>

    </div>
  <% }) %>
</section>

<%- include("partials/footer") %>