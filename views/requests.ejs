<%- include("partials/header", { title: "Requests" }) %>

<section class="hero">
  <h1>Submit a Custom Build Request</h1>

  <form action="/requests" method="post">

    <div>
      <label for="title">Project Title</label>
      <input 
        type="text" 
        id="title" 
        name="title" 
        required
      >
    </div>

    <div>
      <label for="description">Project Description</label>
      <textarea 
        id="description" 
        name="description" 
        rows="5" 
        required
      ></textarea>
    </div>

    <button type="submit">Submit Request</button>

  </form>
</section>

<%- include("partials/footer") %>